PORT=5000
NODE_ENV=development

# MongoDB
# Pour MongoDB Local: mongodb://localhost:27017/pharmacy_manager_bf
# Pour MongoDB Atlas, remplacez les informations par vos identifiants:
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/pharmacy_manager_bf?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_256_bits_random_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Email (nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=PharmacyManager BF <no-reply@pharmacymanager.bf>

# Frontend URL (CORS)
FRONTEND_URL=http://192.168.132.101:3000
MOBILE_URL=http://192.168.132.101:8080

# Admin default
ADMIN_EMAIL=admin@pharmacy.bf
ADMIN_PASSWORD=Admin@1234
